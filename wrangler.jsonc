{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanzaku-frontend-v2",
  "compatibility_date": "2025-03-25",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "tanzaku.mizphses.com",
      "custom_domain": true
    }
  ]
}
